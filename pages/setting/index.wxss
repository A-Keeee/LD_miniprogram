.container {
  min-height: 100vh;
  background-color: #F9FAFB;
  padding: 32rpx 32rpx 140rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 1rpx solid #f3f4f6;
  margin-bottom: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.card-title {
  font-weight: bold;
  color: #7e22ce;
  font-size: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.provider-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.provider-btn {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background-color: #ffffff;
}

.provider-btn:active {
  opacity: 0.85;
}

.provider-btn.active {
  border-color: #a855f7;
  background-color: #faf5ff;
  box-shadow: 0 0 0 2rpx #a855f7;
}

.p-title {
  font-weight: 500;
  color: #1f2937;
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.provider-btn.active .p-title {
  color: #7e22ce;
}

.p-desc {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.4;
}

.api-settings {
  padding-top: 12rpx;
}

.input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 20rpx;
  z-index: 1;
}

.input-box {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx 0 56rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background-color: #ffffff;
  font-size: 26rpx;
}

.input-box.no-icon {
  padding-left: 24rpx;
}

.info-box {
  background-color: #eff6ff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
  align-items: flex-start;
}

.info-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: #1d4ed8;
}

.save-btn {
  width: 100% !important;
  background-color: #111827 !important;
  color: #ffffff !important;
  padding: 24rpx !important;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  display: none;
}

.save-btn.saved {
  background-color: #22c55e !important;
}

.save-btn:active {
  opacity: 0.85;
}
