.container {
  min-height: 100vh;
  background-color: #FDFBF7;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.icon-wrap {
  width: 112rpx;
  height: 112rpx;
  background-color: #f3e8ff;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #6b7280;
  font-size: 28rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.input-text {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background-color: #ffffff;
  font-size: 28rpx;
}

.type-selector {
  display: flex;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.type-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background-color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.type-btn:active {
  opacity: 0.85;
}

.type-btn.active {
  border-color: #a855f7;
  background-color: #faf5ff;
  color: #7e22ce;
}

.emoji {
  font-size: 48rpx;
}

.upload-area {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  border: 3rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  overflow: hidden;
}

.upload-area:active {
  border-color: #a855f7;
  background-color: #faf5ff;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #6b7280;
  font-size: 26rpx;
  gap: 12rpx;
}

.submit-btn {
  width: 100% !important;
  background-color: #111827 !important;
  color: #ffffff !important;
  padding: 24rpx !important;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 24rpx;
  border: none;
}

.submit-btn::after {
  display: none;
}

.submit-btn[disabled] {
  background-color: #9ca3af !important;
  color: #f3f4f6 !important;
  opacity: 0.7;
}

.submit-btn:active {
  opacity: 0.85;
}
